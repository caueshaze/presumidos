# Obrigatorio para subir o servidor.
APP_ENV=development
APP_DOMAIN=example.com
VITE_CONTACT_EMAIL=contato@example.com
DATABASE_PATH=bolao.db
SESSION_SECRET=troque-esta-chave-por-uma-sequencia-longa-e-segura-com-32-ou-mais-caracteres
ADMIN_BOOTSTRAP_SECRET=troque-este-segredo-por-um-valor-exclusivo-para-o-bootstrap-inicial
SESSION_TTL_HOURS=12
COOKIE_SECURE=false
ADMIN_REAUTH_TTL_MINUTES=10
TRUSTED_PROXY_CIDRS=
REQUIRE_TRUSTED_PROXY=false
RATE_LIMIT_BACKEND=memory
REDIS_URL=redis://redis:6379
# Segredo dedicado para o hash de identidade do rate limit (HMAC-SHA256).
# Se nao definido, usa SESSION_SECRET. Recomenda-se um valor proprio com 32+ caracteres.
RATE_LIMIT_IDENTITY_SECRET=troque-este-segredo-por-um-valor-exclusivo-para-o-hash-de-identidade-do-rate-limit
# Politica de hashing de senha (Argon2id). Defaults seguem o crate argon2.
# Aumentar esses valores aciona rehash transparente gradual: cada usuario
# recebe um novo hash na proxima vez que fizer login com sucesso.
ARGON2_MEMORY_KIB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
ARGON2_POLICY_VERSION=v1
# Resend (envio de emails de verificacao/recuperacao de senha)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=Presumidos <onboarding@resend.dev>

# --- Integracao de resultados ao vivo (worldcup26.ir) ---
# Fonte: scoreboard publico da ESPN (FIFA World Cup), sem chave.
# https://github.com/rezarahiminia/worldcup2026
# Liga a integracao. Sem isso, nenhuma chamada externa e feita.
FOOTBALL_API_ENABLED=false
# Sobe o poller em background NESTA instancia. Mantenha 'true' em apenas uma
# replica para nao duplicar requisicoes a API publica.
FOOTBALL_POLLER_ENABLED=false
# Base URL do scoreboard da ESPN (parametros dates/lang/region sao adicionados pelo app).
FOOTBALL_API_BASE_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world/scoreboard
# Intervalo BASE do polling em segundos (default 600 = 10 min). Minimo 60.
# O poller adiciona um jitter aleatorio de 0-60s a cada ciclo.
FOOTBALL_POLL_INTERVAL_SECS=600
# Intervalo (menor) enquanto ha jogo na janela, pra pontuacao ao vivo andar mais rapido. Minimo 60.
FOOTBALL_LIVE_POLL_INTERVAL_SECS=300
# NOTA: essa fonte nao traz penaltis nem o classificado do mata-mata, entao o
# poller so finaliza automaticamente a fase de grupos. No mata-mata ele apenas
# mostra o placar ao vivo; o resultado oficial e lancado pelo admin.

# --- Web Push (lembretes de palpite no navegador) ---
# Liga a infraestrutura de notificacoes web. Requer HTTPS em producao e chaves VAPID validas.
WEB_PUSH_ENABLED=false
# Intervalo do worker em segundos. Minimo 30; recomendado 60.
WEB_PUSH_POLL_INTERVAL_SECS=60
# Chaves VAPID no formato URL-safe base64.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# Email de contato incluido no claim 'sub' do VAPID (ex.: admin@seudominio.com).
WEB_PUSH_CONTACT_EMAIL=
